# Run `python cli.py --setup` to generate .env interactively.
# Generic provider and model keys (recommended).
LLM_PROVIDER=openai
LLM_MODEL=gpt-4o-mini
LLM_API_KEY=

# Provider-specific compatibility aliases (optional).
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_BASE_URL=
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openai/gpt-4o-mini
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Web Search settings (Optional, uses DuckDuckGo by default)
TAVILY_API_KEY=

# Workflow settings
LANGCHAIN_ENABLED=true
USE_HEURISTIC_FALLBACK=false
CODE_EXECUTION_ENABLED=true
CODE_EXECUTION_BACKEND=local # local or e2b
E2B_API_KEY=
MAX_RETRIES=3

# Assistant settings
GWS_BINARY_PATH=gws.exe
LOG_LEVEL=INFO
LOG_FILE_PATH=logs/gws_assistant.log
APP_VERBOSE=true
LLM_TIMEOUT_SECONDS=30
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
DEFAULT_RECIPIENT_EMAIL=user@example.com