# Run `python cli.py --setup` to generate .env interactively.
# Set to openai or openrouter. If empty, OPENROUTER_API_KEY takes priority.
LLM_PROVIDER=openai

# OpenAI settings
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
OPENAI_BASE_URL=

# OpenRouter settings
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openai/gpt-4.1-mini
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Web Search settings (Optional, uses DuckDuckGo by default)
TAVILY_API_KEY=

# Workflow settings
LANGCHAIN_ENABLED=true
CODE_EXECUTION_ENABLED=true
CODE_EXECUTION_BACKEND=restricted_subprocess
CODE_EXECUTION_TIMEOUT_SECONDS=10
CODE_EXECUTION_MEMORY_MB=64
CODE_EXECUTION_MAX_OUTPUT=8192
CODE_EXECUTION_DOCKER_IMAGE=gws-sandbox:latest
CODE_EXECUTION_DOCKER_BINARY=docker
DEFAULT_RECIPIENT_EMAIL=
MAX_RETRIES=3

# Assistant settings
GWS_BINARY_PATH=gws.exe
APP_LOG_LEVEL=INFO
APP_VERBOSE=true
APP_LOG_DIR=logs
LLM_TIMEOUT_SECONDS=30
