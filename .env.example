# Run `python gws_cli.py --setup` to generate .env interactively.

# ==============================================================================
# PRIMARY LLM & ROTATION CONFIGURATION
# ==============================================================================

LLM_PROVIDER=openrouter    # Supported: openrouter, groq, google, openai, anthropic, mistral, ollama
LLM_MODEL=openrouter/google/gemini-2.0-flash-lite-preview-02-05:free

# --- API KEY ROTATION (Priority 1) ---
# If these are set, the agent will rotate through them on RateLimit errors.
# These keys are used for ANY provider selected in LLM_PROVIDER.
LLM_API_KEY=
LLM_API_KEY2=
LLM_API_KEY3=

# Fallback Models (Sequential retry chain if primary fails)
LLM_FALLBACK_MODEL=openrouter/meta-llama/llama-3.3-70b-instruct:free
LLM_FALLBACK_MODEL2=openrouter/qwen/qwen-2.5-72b-instruct:free
LLM_FALLBACK_MODEL3=openrouter/deepseek/deepseek-chat:free

# Generation Parameters
LLM_MAX_TOKENS=
LLM_TEMPERATURE=0
LLM_TIMEOUT_SECONDS=60

# ==============================================================================
# PROVIDER-SPECIFIC FALLBACKS (Priority 2)
# ==============================================================================
# If LLM_API_KEY series above is empty, the agent pulls from these based on provider.

# OpenRouter
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Groq
GROQ_API_KEY=

# Google Gemini
GOOGLE_API_KEY=
# GEMINI_API_KEY= (Alias for GOOGLE_API_KEY)

# OpenAI
OPENAI_API_KEY=

# Anthropic
ANTHROPIC_API_KEY=

# Mistral
MISTRAL_API_KEY=

# Ollama (No key needed)
OLLAMA_API_BASE=http://localhost:11434

# ==============================================================================
# WORKFLOW, PLANNING & MEMORY
# ==============================================================================

# Search & Summarization
TAVILY_API_KEY=   # Optional: For advanced web search if DuckDuckGo is insufficient

# Planning Logic
LANGCHAIN_ENABLED=true
USE_HEURISTIC_FALLBACK=true  # If true, agent uses code-based planning if LLM fails
MAX_RETRIES=3                # LLM request retries
MAX_REPLANS=1                # How many times to re-attempt the entire task flow
MAX_CONTEXT_SNIPPET_LEN=500  # Character limit for search result snippets

# Code Execution (Sandboxing)
CODE_EXECUTION_ENABLED=true
CODE_EXECUTION_BACKEND=local # options: local, e2b
E2B_API_KEY=                 # Required if backend is e2b
SANDBOX_ENABLED=true

# GWS Binary Configuration
GWS_BINARY_PATH=gws          # Path to the compiled gws.exe or gws binary
GWS_TIMEOUT_SECONDS=180      # Timeout for individual workspace commands
GWS_MAX_RETRIES=3            # Retries for failed workspace commands

# ==============================================================================
# ASSISTANT IDENTITY & INTEGRATIONS
# ==============================================================================

DEFAULT_RECIPIENT_EMAIL=     # Default target for 'email me' tasks
TELEGRAM_BOT_TOKEN=          # For telegram interface
TELEGRAM_CHAT_ID=            # For telegram notifications

# Memory settings
MEMORY_TYPE=local            # local or remote (mem0)
MEM0_API_KEY=
MEM0_USER_ID=default_user
MEM0_HOST=
MEM0_LOCAL_STORAGE_PATH=.gemini/memories.jsonl

# Logging & Environment
APP_LOG_DIR=logs
APP_LOG_LEVEL=INFO
APP_VERBOSE=true
READ_ONLY_MODE=true          # If true, prevents destructive workspace operations (recommended)

# ==============================================================================
# FILE EXPORT SANDBOX
# ==============================================================================
# Directories that drive.export_file / drive.get_file are allowed to write into.
# Paths may be absolute or relative to the project root and are normalised to
# handle Windows extended-length prefixes (\\?\) and mixed separators.
DOWNLOADS_DIR=downloads
SCRATCH_DIR=scratch

# ==============================================================================
# DEFAULT WORKSPACE TITLES
# ==============================================================================
# Used when an agent task is missing an explicit title.
DEFAULT_SPREADSHEET_TITLE=GWS Agent Spreadsheet

# ==============================================================================
# MANUAL / VERIFICATION TEST FIXTURES
# ==============================================================================
# Override the names and queries used by the manual & verification suites so
# real-world testing doesn't require editing source code.
TEST_FILE_NAME=README.md                 # File used by attachment manual tests
TEST_DOC_NAME=Investigation Report       # Google Doc title for docs manual tests
TEST_SHEET_NAME=Systematic Testing Data  # Google Sheet title for sheets manual tests
TEST_FOLDER_NAME=Agentic AI Test Folder  # Drive folder name for create/move tests
TEST_RENAMED_FOLDER_NAME=Renamed AI Folder
TEST_DOC_QUERY=MyDocument       # Drive search keyword for export tests
TEST_DOC_KEYWORD=Document                  # Drive content keyword for ID-resolution tests
TEST_DRIVE_SEARCH_QUERY=budget           # Drive list_files keyword for read-only tests
TEST_WEB_SEARCH_QUERY=Agentic AI Google Workspace
TEST_GMAIL_SEARCH_QUERY=invoice
TEST_GMAIL_URGENT_QUERY=urgent
TEST_GMAIL_LABEL_NAME=GWorkspaceAgent-Test
TEST_GMAIL_LABEL_SENDER=your-email@example.com

# Google Keep Test Fixtures
TEST_NOTE_TITLE=GWS Agent Test Note
TEST_NOTE_BODY=Test note content from GWorkspace Agent

# Google Calendar Test Fixtures
TEST_EVENT_NAME=GWS Agent Test Event
TEST_EVENT_DESCRIPTION=Test event created by GWorkspace Agent

# Google Meet Test Fixtures
TEST_MEETING_NAME=GWS Agent Test Meeting

# Google Slides Test Fixtures
TEST_PRESENTATION_TITLE=GWS Agent Test Presentation

# Google Forms Test Fixtures
TEST_FORM_TITLE=GWS Agent Test Form

# Google Chat Test Fixtures
TEST_CHAT_MESSAGE=GWS Agent automated test message

# Google Tasks Test Fixtures
TEST_TASKLIST_TITLE=GWS Agent Test Tasklist
TEST_TASK_TITLE=GWS Agent Test Task

# Google Contacts Test Fixtures
TEST_CONTACT_NAME=GWS Test Contact
TEST_CONTACT_EMAIL=gws-test@example.com

# CRUD Test Sequence Markers
TEST_UPDATE_SUFFIX=Updated
TEST_COPY_SUFFIX=Copy

# ==============================================================================
# VERIFICATION ENGINE CONFIGURATION
# ==============================================================================
# Configuration for the 5-check verification system. These values control
# what the verification engine considers as placeholders, destructive operations,
# and other validation criteria. All values are comma-separated.

# Placeholder detection - strings that indicate incomplete/placeholder values
VERIFICATION_EXACT_PLACEHOLDERS=none,null,n/a,na,undefined,todo,fixme,placeholder,example,sample,dummy,your_value,insert_here,replace_me,changeme,default,fake,mock,temporary,tbd,missing

# Numeric placeholders - common dummy numbers
VERIFICATION_NUMERIC_PLACEHOLDERS=0000,1234,9999,00000000

# Email placeholders - exact email addresses considered as placeholders
VERIFICATION_EXACT_EMAILS=noreply@domain.com

# Email placeholder domains - domains that indicate test/placeholder emails
VERIFICATION_EMAIL_PLACEHOLDER_DOMAINS=@test.com

# Destructive operations - tool names that require explicit safety confirmation
VERIFICATION_DESTRUCTIVE_OPERATIONS=drive_delete_file,drive_empty_trash,drive_move_to_trash,gmail_delete_message,gmail_trash_message,gmail_batch_delete,gmail_empty_trash,sheets_delete_spreadsheet,sheets_clear_all_data,sheets_delete_sheet_tab,docs_delete_document,calendar_delete_event,calendar_delete_calendar,contacts_delete_contact

# Bulk operation indicators - keywords that indicate bulk/multiple operations
VERIFICATION_BULK_INDICATORS=batch,bulk,multiple,all

# ID field names - field names used for ID validation
VERIFICATION_ID_FIELDS=file_id,document_id,spreadsheet_id,message_id,event_id,task_id,contact_id

# Content field names - field names used for content validation
VERIFICATION_CONTENT_FIELDS=body,content,message,text,description

# Create operation ID fields - field names that should be returned by create operations
VERIFICATION_CREATE_ID_FIELDS=id,documentId,spreadsheetId,fileId,messageId,resourceName,threadId,name,formId,taskId,contactId

# Suspicious patterns - regex patterns that indicate suspicious operations (format: name:regex)
VERIFICATION_SUSPICIOUS_PATTERNS=delete_all:delete.*all,remove_everything:remove.*everything,wipe_all:wipe.*all,clear_all:clear.*all
DRIVE_FOLDER_NAME=Temp
