# Copy this file to `.env` and fill in the values you want to use.
# Preferred setup command: `python gws_cli.py --setup`

# LLM settings
# Set to `openai` or `openrouter`. If blank, OpenRouter is used when its key is present.
LLM_PROVIDER=openai

# OpenAI settings
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
OPENAI_BASE_URL=

# OpenRouter settings
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openai/gpt-4.1-mini
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Web search
# DuckDuckGo works without a key. Tavily is used as a higher-quality fallback.
TAVILY_API_KEY=

# Workflow controls
LANGCHAIN_ENABLED=true
MAX_RETRIES=3
DEFAULT_RECIPIENT_EMAIL=

# Code execution
CODE_EXECUTION_ENABLED=true
# Supported values: restricted_subprocess, docker, e2b
CODE_EXECUTION_BACKEND=restricted_subprocess
CODE_EXECUTION_TIMEOUT_SECONDS=10
CODE_EXECUTION_MEMORY_MB=64
CODE_EXECUTION_MAX_OUTPUT=8192
CODE_EXECUTION_DOCKER_IMAGE=gws-sandbox:latest
CODE_EXECUTION_DOCKER_BINARY=docker
E2B_API_KEY=

# Assistant settings
GWS_BINARY_PATH=gws.exe
APP_LOG_LEVEL=INFO
APP_VERBOSE=true
APP_LOG_DIR=logs
LLM_TIMEOUT_SECONDS=30
