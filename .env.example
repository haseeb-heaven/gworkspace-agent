# Run `python gws_cli.py --setup` to generate .env interactively.

# Primary LLM Configuration
LLM_PROVIDER=openrouter  # openrouter, groq, ollama, openai
LLM_MODEL=openrouter/free
LLM_API_KEY=
LLM_MAX_TOKENS=
LLM_TEMPERATURE=0
LLM_TIMEOUT_SECONDS=30

# Fallback Models (used when primary fails or is rate-limited)
LLM_FALLBACK_MODEL=
LLM_FALLBACK_MODEL2=
LLM_FALLBACK_MODEL3=

# OpenRouter specific
OPENROUTER_API_KEY=
OPENROUTER_API_KEY1=
OPENROUTER_API_KEY2=
OPENROUTER_API_KEY3=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Groq specific
GROQ_API_KEY=

# Ollama specific
OLLAMA_API_BASE=http://localhost:11434

# OpenAI specific (if using direct provider)
OPENAI_API_KEY=

# Web Search settings (Optional, uses DuckDuckGo by default)
TAVILY_API_KEY=

# Workflow and Planning
LANGCHAIN_ENABLED=true
USE_HEURISTIC_FALLBACK=false
MAX_RETRIES=3
MAX_REPLANS=1
MAX_CONTEXT_SNIPPET_LEN=300

# Code Execution (Sandboxing)
CODE_EXECUTION_ENABLED=true
CODE_EXECUTION_BACKEND=local # local or e2b
E2B_API_KEY=
SANDBOX_ENABLED=true

# GWS Runtime settings
GWS_BINARY_PATH=gws
GWS_TIMEOUT_SECONDS=180
GWS_MAX_RETRIES=3

# Assistant UI & Notifications
DEFAULT_RECIPIENT_EMAIL=user@example.com
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Memory Configuration
MEMORY_TYPE=local # local or remote (mem0)
MEM0_API_KEY=
MEM0_USER_ID=default_user
MEM0_HOST=
MEM0_LOCAL_STORAGE_PATH=.gemini/memories.jsonl

# Logging & Safety
APP_LOG_DIR=logs
APP_LOG_LEVEL=INFO
APP_VERBOSE=true
READ_ONLY_MODE=true
